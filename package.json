{
  "name": "web-penugasan-komatik",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w apps/frontend",
    "dev:backend": "npm run dev -w apps/backend",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "build": "npm run build -w apps/frontend",
    "start": "npm run start -w apps/frontend",
    "lint": "npm run lint -w apps/frontend",
    "test": "node --test --import tsx"
  },
  "devDependencies": {
    "tsx": "^4.20.0",
    "typescript": "^5.9.2"
  }
}
